# Search backend: duckduckgo, tavily, perplexity, searxng, advanced
SEARCH_API=duckduckgo

# LLM provider: ollama, lmstudio, custom
LLM_PROVIDER=custom
LOCAL_LLM=llama3.2
LLM_MODEL_ID=your-model-name
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=your-api-base-url

# Local OpenAI-compatible endpoints
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Research behavior
MAX_WEB_RESEARCH_LOOPS=3
FETCH_FULL_PAGE=true
STRIP_THINKING_TOKENS=true
USE_TOOL_CALLING=false
ENABLE_NOTES=true
NOTES_WORKSPACE=./notes

# Experimental migration switch.
# Keep false for the existing HelloAgents workflow.
USE_LANGGRAPH_WORKFLOW=false

# Optional API keys for search providers
# TAVILY_API_KEY=tvly-xxxxx
# PERPLEXITY_API_KEY=pplx-xxxxx
# SEARXNG_URL=http://localhost:8888
